---
import BaseLayout from "../layouts/BaseLayout.astro";
---

<BaseLayout title="Your Name — Personal Site">
<section class="page active" id="guitar">
  <div class="sec-eye en">Strings &amp; Frets</div><div class="sec-eye zh" style="display:none">弦与品</div>
  <h1 class="sec-h1 en">Guitar</h1><h1 class="sec-h1 zh" style="display:none">吉他</h1>
  <div class="sec-rule"></div>
  <p class="tarot-intro en">Songs I play, have learned, or keep coming back to. Tabs and sheet music links included where available.</p>
  <p class="tarot-intro zh" style="display:none">我弹的歌——学过的、在练的、反复回味的。附谱可点击。</p>

  <div class="guitar-filters">
    <button class="photo-topic-btn on" onclick="filterGuitar(this,'all')"><span class="en">All</span><span class="zh" style="display:none">全部</span></button>
    <button class="photo-topic-btn" onclick="filterGuitar(this,'fingerstyle')"><span class="en">Fingerstyle</span><span class="zh" style="display:none">指弹</span></button>
    <button class="photo-topic-btn" onclick="filterGuitar(this,'classical')"><span class="en">Classical</span><span class="zh" style="display:none">古典</span></button>
    <button class="photo-topic-btn" onclick="filterGuitar(this,'pop')"><span class="en">Pop</span><span class="zh" style="display:none">流行</span></button>
    <button class="photo-topic-btn" onclick="filterGuitar(this,'folk')"><span class="en">Folk</span><span class="zh" style="display:none">民谣</span></button>
  </div>

  <div class="guitar-list" id="guitar-list">

    <div class="guitar-item" data-genre="folk">
      <div class="guitar-item-left">
        <div class="guitar-genre-tag en">Folk</div><div class="guitar-genre-tag zh" style="display:none">民谣</div>
        <div class="guitar-title en">安河桥</div><div class="guitar-title zh" style="display:none">安河桥</div>
        <div class="guitar-artist">宋冬野</div>
      </div>
      <div class="guitar-item-right">
        <span class="guitar-diff guitar-diff-med en">Intermediate</span><span class="guitar-diff guitar-diff-med zh" style="display:none">中级</span>
        <div class="guitar-links">
          <a class="guitar-link" href="https://tabs.ultimate-guitar.com/tab/song-dongye/an-he-qiao-chords-2154505" target="_blank">Chords</a>
          <a class="guitar-link" href="https://www.youtube.com/results?search_query=安河桥+吉他" target="_blank">Video</a>
        </div>
      </div>
    </div>
    
    <div class="guitar-item" data-genre="folk">
      <div class="guitar-item-left">
        <div class="guitar-genre-tag en">Folk</div><div class="guitar-genre-tag zh" style="display:none">民谣</div>
