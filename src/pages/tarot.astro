---
import BaseLayout from "../layouts/BaseLayout.astro";
import { tarotItems, tarotGroups } from "../data/tarotData";
---

<BaseLayout title="Your Name — Personal Site">
  <section class="page active" id="tarot">
    <div class="sec-eye en">Tarot Deck</div>
    <div class="sec-eye zh" style="display:none">塔罗牌组</div>

    <h1 class="sec-h1 en">Tarot</h1>
    <h1 class="sec-h1 zh" style="display:none">塔罗</h1>

    <div class="sec-rule"></div>

    <p class="tarot-intro en">
      I study tarot as a symbolic system — seventy-eight archetypal images that map human experience,
      from innocence and desire to loss, discipline, illusion, and renewal. Click any card to read my
      notes on its symbolism and meaning.
    </p>
    <p class="tarot-intro zh" style="display:none">
      我将塔罗视作一套象征体系——七十八张原型图像，共同映照人的经验：从天真与欲望，到失去、克制、幻觉与重生。
      点击任意一张牌，可以查看我对它的象征与含义的笔记。
    </p>

    {tarotGroups.map((group) => (
      <div class="tarot-group">
        <div class="tarot-group-head">
          <h2 class="en">{group.titleEn}</h2>
          <h2 class="zh" style="display:none">{group.titleZh}</h2>
        </div>

        <div class="tarot-grid">
          {tarotItems
            .filter((item) => item.group === group.key)
            .map((card) => (
              <div class="tarot-card-wrap" onclick={`openModal('${card.id}')`}>
                <div class="tarot-card">
                  <span class="tc-number">{card.displayNumber}</span>
                  <span class="tc-symbol">{card.emoji}</span>
                  <span class="tc-name en">{card.titleEn}</span>
                  <span class="tc-name zh" style="display:none">{card.titleZh}</span>
                </div>
                <div class="tarot-card-label en">{card.titleEn}</div>
                <div class="tarot-card-label zh" style="display:none">{card.titleZh}</div>
              </div>
            ))}
        </div>
      </div>
    ))}
  </section>
</BaseLayout>
