---
import "../styles/global.css";
import Topbar from "../components/Topbar.astro";
import Sidebar from "../components/Sidebar.astro";
import Modal from "../components/Modal.astro";

const { title = "Your Name — Personal Site" } = Astro.props;
const currentPath = Astro.url.pathname.replace(/\/$/, "") || "/";
---

<html lang="en">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <title>{title}</title>
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link href="https://fonts.googleapis.com/css2?family=Lora:ital,wght@0,400;0,500;0,600;1,400;1,500&family=Source+Sans+3:wght@300;400;500;600&family=Noto+Serif+SC:wght@300;400;500;600&family=JetBrains+Mono:wght@400&display=swap" rel="stylesheet" />

    <meta name="google-site-verification" content="zENV1CA8qk6ukQJH7NfKkeFLyXG8Kmvk9sf7CHtqFUo" />
    
    <!-- Google tag (gtag.js) -->
    <script async src="https://www.googletagmanager.com/gtag/js?id=G-HW16C3GSXR"></script>
    <script>
      window.dataLayer = window.dataLayer || [];
      function gtag(){dataLayer.push(arguments);}
      gtag('js', new Date());
    
      gtag('config', 'G-HW16C3GSXR');
    </script>
  </head>
  <body>
    <div id="overlay" onclick="closeSidebar()"></div>
    <Topbar />
    <Sidebar currentPath={currentPath} />
    <main id="main">
      <slot />
      <Modal />
    </main>

    <script is:inline>
      // 切换 selected / date / topic 三种视图
      window.showPubView = function (page, view) {
        const prefix = page === 'home' ? 'home' : 'full';
      
        // 隐藏所有视图
        ['selected', 'date', 'topic'].forEach(v => {
          const el = document.getElementById(`${prefix}-view-${v}`);
          if (el) el.style.display = 'none';
        });
      
        // 显示目标视图
        const target = document.getElementById(`${prefix}-view-${view}`);
        if (target) target.style.display = '';
      
        // 更新 active-toggle 样式（英文和中文两套）
        ['', '-zh'].forEach(suffix => {
          ['selected', 'date', 'topic'].forEach(v => {
            const btn = document.getElementById(`${prefix}-${v === 'selected' ? 'sel' : v}${suffix}`);
            if (btn) btn.classList.toggle('active-toggle', v === view);
          });
        });
      
        // 切换到 topic 视图时，取消所有 topic 过滤高亮
        if (view === 'topic') {
          document.querySelectorAll(`#${prefix}-view-topic .pub-topic-group`).forEach(g => {
            g.style.display = '';
          });
          document.querySelectorAll(`#${prefix}-view-topic .topic-link`).forEach(l => {
            l.classList.remove('active-toggle');
          });
        }
      };
      
      // 按 topic 过滤，先切到 topic 视图再筛选
      window.filterByTopic = function (page, topic) {
        // 先切换到 topic 视图
        window.showPubView(page, 'topic');
      
        const prefix = page === 'home' ? 'home' : 'full';
        const topicView = document.getElementById(`${prefix}-view-topic`);
        if (!topicView) return;
      
        // 显示/隐藏对应的 topic 分组
        topicView.querySelectorAll('.pub-topic-group').forEach(g => {
          g.style.display = g.id === `${prefix}-topic-${topic}` ? '' : 'none';
        });
      };

      window.setLang = function (lang) {
        const isZh = lang === 'zh';
    
        document.documentElement.lang = isZh ? 'zh-CN' : 'en';
    
        document.querySelectorAll('.en').forEach((el) => {
          el.style.display = isZh ? 'none' : '';
        });
    
        document.querySelectorAll('.zh').forEach((el) => {
          el.style.display = isZh ? '' : 'none';
        });
    
        const btnEn = document.getElementById('btn-en');
        const btnZh = document.getElementById('btn-zh');
    
        if (btnEn && btnZh) {
          btnEn.classList.toggle('on', !isZh);
          btnZh.classList.toggle('on', isZh);
        }
    
        localStorage.setItem('lang', lang);
      };
    
      window.addEventListener('DOMContentLoaded', () => {
        const saved = localStorage.getItem('lang') || 'en';
        window.setLang(saved);
      });
    </script>
  </body>
</html>
