---
import "../styles/global.css";
import Topbar from "../components/Topbar.astro";
import Sidebar from "../components/Sidebar.astro";
import Modal from "../components/Modal.astro";

const { title = "Your Name — Personal Site" } = Astro.props;
const currentPath = Astro.url.pathname.replace(/\/$/, "") || "/";
---

<html lang="en">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <title>{title}</title>
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link href="https://fonts.googleapis.com/css2?family=Lora:ital,wght@0,400;0,500;0,600;1,400;1,500&family=Source+Sans+3:wght@300;400;500;600&family=Noto+Serif+SC:wght@300;400;500;600&family=JetBrains+Mono:wght@400&display=swap" rel="stylesheet" />
  </head>
  <body>
    <div id="overlay" onclick="closeSidebar()"></div>
    <Topbar />
    <Sidebar currentPath={currentPath} />
    <main id="main">
      <slot />
      <Modal />
    </main>

    <script is:inline>
      window.setLang = function (lang) {
        const isZh = lang === 'zh';

        document.documentElement.lang = isZh ? 'zh-CN' : 'en';

        document.querySelectorAll('.en').forEach((el) => {
          el.style.display = isZh ? 'none' : '';
        });

        document.querySelectorAll('.zh').forEach((el) => {
          el.style.display = isZh ? '' : 'none';
        });

        localStorage.setItem('lang', lang);
      };

      window.addEventListener('DOMContentLoaded', () => {
        const saved = localStorage.getItem('lang') || 'en';
        window.setLang(saved);
      });
    </script>
  </body>
</html>
