// ── Navigation ──────────────────────────────────────────────────────────────
function show(id) {
  document.querySelectorAll('.page').forEach(p => p.classList.remove('active'));
  document.querySelectorAll('.sb-nav a').forEach(a => a.classList.remove('active'));
  const page = document.getElementById(id);
  if (page) page.classList.add('active');
  const nav = document.getElementById('nav-' + id);
  if (nav) nav.classList.add('active');
  window.scrollTo({top: 0, behavior: 'smooth'});
  closeSidebar();
}

// ── Language toggle ──────────────────────────────────────────────────────────
function setLang(lang) {
  const other = lang === 'en' ? 'zh' : 'en';
  document.querySelectorAll('.' + lang).forEach(el => el.style.display = '');
  document.querySelectorAll('.' + other).forEach(el => el.style.display = 'none');
  document.getElementById('btn-en').classList.toggle('on', lang === 'en');
  document.getElementById('btn-zh').classList.toggle('on', lang === 'zh');
  document.documentElement.lang = lang === 'zh' ? 'zh-CN' : 'en';
}

// ── Publications view toggle ─────────────────────────────────────────────────
function showPubView(ctx, view) {
  ['selected', 'date', 'topic'].forEach(v => {
    const el = document.getElementById(ctx + '-view-' + v);
    if (el) el.style.display = v === view ? '' : 'none';
  });
  const keyMap = {sel: 'selected', date: 'date', topic: 'topic'};
  Object.entries(keyMap).forEach(([k, v]) => {
    const el = document.getElementById(ctx + '-' + k);
    const elZh = document.getElementById(ctx + '-' + k + '-zh');
    if (el) el.classList.toggle('active-toggle', v === view);
    if (elZh) elZh.classList.toggle('active-toggle', v === view);
  });
  document.querySelectorAll('[id^="' + ctx + '-topic-"]').forEach(g => g.style.opacity = '1');
}

function filterByTopic(ctx, topic) {
  showPubView(ctx, 'topic');
  document.querySelectorAll('[id^="' + ctx + '-topic-"]').forEach(g => {
    g.style.opacity = (g.id === ctx + '-topic-' + topic) ? '1' : '0.35';
  });
}

// ── Photography filter ───────────────────────────────────────────────────────
function filterPhoto(btn, topic) {
  document.querySelectorAll('.photo-topic-btn').forEach(b => b.classList.remove('on'));
  btn.classList.add('on');
  document.querySelectorAll('.photo-cell').forEach(cell => {
    cell.style.display = (topic === 'all' || cell.dataset.topic === topic) ? '' : 'none';
  });
}

// ── Guitar filter ────────────────────────────────────────────────────────────
function filterGuitar(btn, genre) {
  document.querySelectorAll('.guitar-filters .photo-topic-btn').forEach(b => b.classList.remove('on'));
  btn.classList.add('on');
  document.querySelectorAll('.guitar-item').forEach(item => {
    item.style.display = (genre === 'all' || item.dataset.genre === genre) ? '' : 'none';
  });
}

// ── WeChat expand ────────────────────────────────────────────────────────────
function toggleContact(e, id) {
  e.preventDefault();
  const detail = document.getElementById(id);
  const arrow = document.getElementById(id.replace('-detail', '-arrow'));
  if (detail) detail.classList.toggle('open');
  if (arrow) arrow.classList.toggle('open');
}

// ── Mobile sidebar ───────────────────────────────────────────────────────────
function openSidebar() {
  document.getElementById('sidebar').classList.add('open');
  document.getElementById('overlay').classList.add('show');
}
function closeSidebar() {
  document.getElementById('sidebar').classList.remove('open');
  document.getElementById('overlay').classList.remove('show');
}

// ── Modal ────────────────────────────────────────────────────────────────────
window.openModal = function (id) {
  const d = MODALS[id];
  if (!d) return;

  const isZh = document.documentElement.lang === 'zh-CN';
  const title   = isZh ? d.titleZh   : d.titleEn;
  const eyebrow = isZh ? d.eyebrowZh : d.eyebrowEn;
  const meta    = isZh ? d.metaZh    : d.metaEn;
  const ingr    = isZh ? d.ingrZh    : d.ingrEn;
  const steps   = isZh ? d.stepsZh   : d.stepsEn;
  const notes   = isZh ? d.notesZh   : d.notesEn;

  const isTarot = id.startsWith('tarot-');
  const isBook = id.startsWith('book');
  const isCocktail = id.startsWith('cocktail');
  const isProj = id.startsWith('proj');

  document.getElementById('modal-hero').innerHTML =
    (d.img
      ? '<img src="' + d.img + '" alt="' + title + '" style="width:100%;height:100%;object-fit:cover;">'
      : '<span style="font-size:5rem">' + d.emoji + '</span>') +
    '<button class="modal-close" onclick="closeModal()">✕</button>';

  let metaHtml = '';
  meta.forEach(function(pair) {
    metaHtml += '<div class="modal-meta"><strong>' + pair[0] + ':</strong> ' + pair[1] + '</div>';
  });

  let html =
    '<div class="modal-eyebrow">' + eyebrow + '</div>' +
    '<h2 class="modal-title">' + title + '</h2>' +
    '<div class="modal-meta-row">' + metaHtml + '</div>';

  if (!isTarot && !isBook && !isProj) {
    if (ingr && ingr.length) {
      html += '<div class="modal-section-title">' + (isZh ? '配方' : 'Ingredients') + '</div><ul class="modal-list">';
      ingr.forEach(function(item) {
        html += '<li>' + item + '</li>';
      });
      html += '</ul>';
    }

    if (steps && steps.length) {
      html += '<div class="modal-section-title">' + (isCocktail ? (isZh ? '做法' : 'Method') : (isZh ? '步骤' : 'Steps')) + '</div><ol class="modal-list">';
      steps.forEach(function(item) {
        html += '<li>' + item + '</li>';
      });
      html += '</ol>';
    }
  }

  if (notes) {
    html += '<div class="modal-section-title">' +
      (isTarot ? (isZh ? '象征意义' : 'Symbolism / Meaning')
      : isBook ? (isZh ? '笔记 / 摘录' : 'Notes / Excerpts')
      : isProj ? (isZh ? '说明' : 'Description')
      : (isZh ? '注' : 'Notes')) +
      '</div>';

    html += '<div class="modal-notes">' +
      notes.replace(/\n/g, '<br>') +
      '</div>';
  }

  document.getElementById('modal-content').innerHTML = html;
  document.getElementById('modal-overlay').classList.add('open');
  document.body.classList.add('modal-open');
};

window.closeModal = function () {
  document.getElementById('modal-overlay').classList.remove('open');
  document.body.classList.remove('modal-open');
};

window.closeModalIfBg = function (event) {
  if (event.target && event.target.id === 'modal-overlay') {
    window.closeModal();
  }
};
</script>
